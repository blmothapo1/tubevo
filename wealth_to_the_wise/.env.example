# ──────────────────────────────────────────────────
# Wealth to the Wise — Environment Variables
# Copy this file to .env and fill in your real values
# ──────────────────────────────────────────────────

# Path to your Google OAuth2 client secrets JSON
# Download from: Google Cloud Console → APIs & Services → Credentials
YOUTUBE_CLIENT_SECRETS=client_secrets.json

# Where to cache the OAuth2 refresh token (auto-created after first login)
YOUTUBE_OAUTH_TOKEN=token.json

# Your OpenAI API key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube video category ID (22 = People & Blogs)
DEFAULT_VIDEO_CATEGORY=22

# Comma-separated default tags added to every upload
DEFAULT_TAGS=wealth,money,frugality,financial literacy,success habits,personal finance

# Default privacy status: private | unlisted | public
DEFAULT_PRIVACY=private

# YouTube playlist ID — uploaded videos will be added to this playlist.
# Leave empty to skip playlist assignment.  Find the ID in YouTube Studio
# or from the playlist URL: youtube.com/playlist?list=PLxxxxxxxxxxxxxxxx
DEFAULT_PLAYLIST_ID=

# ElevenLabs TTS (for --auto mode)
ELEVENLABS_API_KEY=your-elevenlabs-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here

# Pexels API key for stock footage (free: https://www.pexels.com/api/)
PEXELS_API_KEY=your-pexels-api-key-here

# Maximum video file size (MB) before compression kicks in (default: 200)
MAX_VIDEO_SIZE_MB=200

# Channel voice used in script-generation prompts
CHANNEL_TONE=You are 'Wealth to the Wise', a confident and direct financial educator. No fluff, no filler. You tell the viewer exactly what to do. Your topics revolve around wealth-building, frugality, success habits, and financial literacy. Every sentence earns its place.

# ──────────────────────────────────────────────────
# Phase 2 — SaaS Backend
# ──────────────────────────────────────────────────

# Debug mode (enables auto-reload, verbose errors)
DEBUG=false

# Backend server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,https://tubevo.us,https://www.tubevo.us

# Rate limit (SlowAPI syntax: "60/minute", "100/hour", etc.)
RATE_LIMIT_DEFAULT=60/minute

# JWT — REQUIRED. Generate a real secret before running:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Database URL (SQLite for dev, swap to PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./wealth.db

# Google OAuth2 (for per-user YouTube auth in Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ──────────────────────────────────────────────────
# Stripe (payments)
# ──────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────────
# Cloudflare R2 — Temporary Video Storage
# ──────────────────────────────────────────────────
# R2 is S3-compatible object storage used as a transient buffer.
# Videos are uploaded here before being pushed to YouTube, then
# immediately deleted.  Get credentials from the Cloudflare dashboard:
# Dashboard → R2 → Manage R2 API Tokens → Create API Token

# Your Cloudflare account ID (visible in the dashboard URL or R2 overview)
R2_ACCOUNT_ID=

# API token credentials (create an R2-scoped token with Object Read & Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name (create one in the R2 dashboard, e.g. "tubevo-videos")
R2_BUCKET_NAME=tubevo-videos

# ──────────────────────────────────────────────────
# Frontend (Vite — prefix with VITE_ to expose)
# ──────────────────────────────────────────────────

# Backend API base URL.  Leave empty in dev (Vite proxy handles it).
# Set to your deployed backend URL in production.
VITE_API_URL=https://api.tubevo.us
